{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/src/api/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(auth|sessions|audit)(.*)",
      "dest": "backend/src/api/server.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}